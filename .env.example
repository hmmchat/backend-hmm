# App
NODE_ENV=development
PORT=3000

# URLs (domains)
FRONTEND_PUBLIC_URL=https://app.hmmchat.live
FRONTEND_STAGING_URL=https://staging.hmmchat.live
BACKEND_PUBLIC_URL=https://api.hmmchat.live

# Database (each service has its own - see apps/<service>/.env.example)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=replace_this_access_secret
JWT_REFRESH_SECRET=replace_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email / external
BREVO_API_KEY=
SENTRY_DSN=

# Cloudflare R2 (placeholders)
R2_BUCKET=hmmchat-uploads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://app.hmmchat.live/uploads
