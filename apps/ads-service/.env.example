# Service Configuration
PORT=3010
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ads-service?schema=public

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Ad Reward Configuration
AD_REWARD_COINS_PER_AD=10
AD_REWARD_COOLDOWN_SECONDS=300
AD_REWARD_MAX_PER_DAY=20
AD_REWARD_ENABLED=true
# Production must set this and validate provider/SSV reward signatures before minting coins.
AD_REWARD_VERIFICATION_SECRET=change-me-in-production
# Local-only fallback when no real rewarded-ad provider is installed.
AD_REWARD_ALLOW_CLIENT_ATTESTATION=false
TEST_ENDPOINTS_ENABLED=false

# Wallet Service Integration
WALLET_SERVICE_URL=http://localhost:3005
INTERNAL_SERVICE_TOKEN=change-me-in-production

# Ad Network Configuration (Optional - for server-side verification)
# Option 1: Google Ad Manager
AD_MANAGER_NETWORK_ID=
AD_MANAGER_AD_UNIT_PATH=

# Option 2: Google AdSense (if using AdSense instead)
ADSENSE_PUBLISHER_ID=
ADSENSE_AD_UNIT_ID=

# JWT Configuration (for authentication)
JWT_PUBLIC_JWK={"kty":"EC","crv":"P-256","x":"...","y":"..."}
