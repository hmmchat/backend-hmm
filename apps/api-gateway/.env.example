PORT=3000
NODE_ENV=development

# CORS - comma-separated origins (include dashboard for local dev)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3020,https://app.hmmchat.live,https://dashboard.beam.place

# Auth (JWT/JWKS)
JWT_ISSUER=backend-hmm
JWT_AUDIENCE=backend-hmm
# AUTH_PRIVATE_KEY_PEM=...
# AUTH_PUBLIC_JWKS_URL=http://localhost:3010/.well-known/jwks.json

# Redis (if used)
REDIS_URL=redis://localhost:6379

# --- Gateway tuning (change without code) ---
# Health check cache (ms) - how long /health reuses cached results
HEALTH_CACHE_TTL_MS=8000
# Per-service health check timeouts (ms)
HEALTH_CHECK_TIMEOUT_SIMPLE_MS=5000
HEALTH_CHECK_TIMEOUT_WITH_DEPS_MS=15000
# Circuit breaker: failures before opening, window (ms), recovery (ms)
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_WINDOW_MS=60000
CIRCUIT_BREAKER_RECOVERY_MS=15000
# Default proxy request timeout (ms) to backend services
PROXY_DEFAULT_TIMEOUT_MS=10000

# R2/S3 (files-service)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
