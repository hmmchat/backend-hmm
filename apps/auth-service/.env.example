DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auth-service?schema=public"

# JWT Ed25519 keys (PEM). Generate with: openssl genpkey -algorithm ed25519 -out jwt-private.pem && openssl pkey -in jwt-private.pem -pubout -out jwt-public.pem
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...base64...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_JWK='{"kty":"OKP","crv":"Ed25519","x":"..."}'

# Refresh token session expiry (days) - tune without code changes
REFRESH_TOKEN_EXPIRY_DAYS=30

# Request timeout (ms). Should be less than gateway timeout
AUTH_REQUEST_TIMEOUT_MS=8000

# Shared service-to-service token used by user-service to call internal auth endpoints
INTERNAL_SERVICE_TOKEN=change-me-in-production

# Max attempts when generating unique referral code (fallback to longer code if exceeded)
REFERRAL_CODE_MAX_GENERATION_ATTEMPTS=10

# Referral screen API defaults
REFERRAL_REWARD_REFERRER=100
REFERRAL_REWARD_REFERRED=50
REFERRAL_SUCCESS_CRITERIA_LABEL="Profile completed"
REFERRAL_SHARE_BASE_URL="https://sandbox.rbshstudio.com"
REFERRAL_SHARE_QUERY_PARAM="ref"
# Optional: short-link base for QR/deep links. Supports:
# - "https://your-domain.com/r"       -> deepLink: https://your-domain.com/r/<code>
# - "https://your-domain.com/r/{code}" -> deepLink: https://your-domain.com/r/<code>
REFERRAL_SHARE_SHORT_BASE_URL=""
REFERRAL_SHARE_TEMPLATE="Join me on Beam! Use my referral code {code} and get rewards: {link}"

# OAuth
GOOGLE_CLIENT_ID="your.apps.googleusercontent.com"

# Facebook
FB_APP_ID="..."
FB_APP_SECRET="..."

# Apple – no client secret needed to verify identity token
APPLE_AUD="com.your.bundle.id"

# Twilio Verify
TWILIO_ACCOUNT_SID="ACxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxx"
TWILIO_VERIFY_SID="VAXxxxxxxxx"

# CORS
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"
