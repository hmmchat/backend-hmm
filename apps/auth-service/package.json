{
  "name": "auth-service",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start:dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate && node scripts/postinstall-prisma.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "echo '⚠️  WARNING: prisma:push can drop tables! Use prisma:migrate instead.' && prisma db push --accept-data-loss",
    "prisma:deploy": "prisma migrate deploy",
    "postinstall": "node scripts/postinstall-prisma.js"
  },
  "dependencies": {
    "@hmm/common": "*",
    "@nestjs/common": "^10.4.20",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^10.4.20",
    "@nestjs/platform-fastify": "^10.4.20",
    "argon2": "^0.40.3",
    "google-auth-library": "^9.14.2",
    "jose": "^5.2.4",
    "node-fetch": "^3.3.2",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "twilio": "^5.3.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.2",
    "@nestjs/testing": "^10.4.7",
    "@prisma/client": "^6.0.0",
    "@types/node": "^25.0.3",
    "prisma": "^6.0.0",
    "typescript": "^5.6.3"
  }
}
