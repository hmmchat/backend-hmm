PORT=3004
NODE_ENV=development

# Database (if used)
DATABASE_URL=postgresql://user:password@localhost:5432/discovery-service?schema=public

# Auth (JWT/JWKS)
JWT_ISSUER=backend-hmm
JWT_AUDIENCE=backend-hmm
# AUTH_PRIVATE_KEY_PEM=...
# AUTH_PUBLIC_JWKS_URL=http://localhost:3010/.well-known/jwks.json

# Redis (if used)
REDIS_URL=redis://localhost:6379

# --- Discovery match scoring (card ranking) ---
# Points per common brand
MATCH_SCORE_BRAND=10
# Points per exact interest match (same sub-genre)
MATCH_SCORE_INTEREST_EXACT=15
# Points per genre match (same genre, different sub-genre)
MATCH_SCORE_INTEREST_GENRE=10
# Points per common value
MATCH_SCORE_VALUE=20
# Points when music preference matches
MATCH_SCORE_MUSIC=30
# Points when same city (anywhere mode)
MATCH_SCORE_SAME_CITY=50
# Points when video preference matches
MATCH_SCORE_VIDEO=100

# --- Broadcast recommendation scoring ---
MATCH_SCORE_BROADCAST_TRENDING=50
MATCH_SCORE_BROADCAST_POPULARITY_CAP=30
MATCH_SCORE_BROADCAST_VIEWERS_CAP=20
MATCH_SCORE_BROADCAST_RECENCY_VERY=15
MATCH_SCORE_BROADCAST_RECENCY_RECENT=10
MATCH_SCORE_BROADCAST_RECENCY_TODAY=5
MATCH_SCORE_BROADCAST_TAG=5

# --- Discovery pool & location limits ---
# Max users to fetch for card pool / matching
DISCOVERY_POOL_LIMIT=500
# Max users per city for cities/nearby endpoints
CITIES_MAX_USERS_LIMIT=100

# --- Squad ---
# Invitation expiry (ms). Default 10 min
SQUAD_INVITATION_TIMEOUT_MS=600000
# Max squad size (1 inviter + 2 invitees = 3)
MAX_SQUAD_SIZE=3

# R2/S3 (files-service)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
