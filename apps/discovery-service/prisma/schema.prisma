// Prisma schema for discovery-service
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

// Gender filter preference for users
// Note: Gender enum is defined in user-service schema and shared via same database
model GenderFilterPreference {
  id               String    @id @default(cuid())
  userId           String    @unique
  genders          Json // Array of Gender enum values: ["MALE", "FEMALE", "NON_BINARY"] (stored as JSON)
  screensRemaining Int       @default(0) // Number of screens remaining for this filter
  expiresAt        DateTime? // When the filter expires (if applicable)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@map("gender_filter_preferences")
}
