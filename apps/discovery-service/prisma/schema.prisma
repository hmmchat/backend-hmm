// Prisma schema for discovery-service
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

// Note: Wallet and Transaction tables are owned by wallet-service.
// Access wallet data via HTTP API calls to wallet-service, not direct database access.

// Tables owned and managed by discovery-service
// These tables are in the discovery-service database

// Gender filter preference for users
// Note: Gender enum values stored as JSON strings; no shared DB dependency
model GenderFilterPreference {
  id               String    @id @default(cuid())
  userId           String    @unique
  genders          Json // Array of Gender enum values: ["MALE", "FEMALE", "NON_BINARY"] (stored as JSON)
  screensRemaining Int       @default(0) // Number of screens remaining for this filter
  expiresAt        DateTime? // When the filter expires (if applicable)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@map("gender_filter_preferences")
}

// Track rainchecked users per session
// Rainchecked users are hidden until next session (new sessionId) or city change
model RaincheckSession {
  id                String   @id @default(cuid())
  userId            String // User who rainchecked
  sessionId         String // Frontend-generated session ID
  raincheckedUserId String // User who was rainchecked
  city              String? // City context (null for "anywhere")
  createdAt         DateTime @default(now())

  @@index([userId, sessionId])
  @@index([userId, city, sessionId])
  @@map("raincheck_sessions")
}

// Track active matches between users
// When users are matched, both see each other's cards
// Matches do NOT expire - they persist until someone rainchecks
model ActiveMatch {
  id        String    @id @default(cuid())
  user1Id   String // First user in the match
  user2Id   String // Second user in the match
  score     Float // Mutual compatibility score
  expiresAt DateTime? // Optional - not used (matches don't expire until raincheck)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@index([expiresAt])
  @@map("active_matches")
}

// Track match acceptances for two-phase proceed
// Each user accepts separately, both must accept to proceed to IN_SQUAD
model MatchAcceptance {
  id         String   @id @default(cuid())
  user1Id    String // First user in the match
  user2Id    String // Second user in the match
  acceptedBy String // User who accepted (user1Id or user2Id)
  createdAt  DateTime @default(now())
  expiresAt  DateTime // When the match expires if not both accepted

  @@unique([user1Id, user2Id, acceptedBy])
  @@index([user1Id, user2Id])
  @@index([expiresAt])
  @@map("match_acceptances")
}

// Squad invitation system
enum SquadInvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

model SquadInvitation {
  id          String                @id @default(cuid())
  inviterId   String                // User who sent the invitation
  inviteeId   String?               // User who was invited (null for external invites)
  inviteToken String?               @unique // Token for external links (unique)
  status      SquadInvitationStatus @default(PENDING)
  expiresAt   DateTime              // 10-minute timeout
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  acceptedAt  DateTime?
  rejectedAt  DateTime?

  @@index([inviterId, status])
  @@index([inviteeId, status])
  @@index([inviteToken])
  @@index([expiresAt])
  @@index([status])
  @@map("squad_invitations")
}

enum SquadLobbyStatus {
  WAITING  // Waiting for more members
  READY    // Has at least 2 members, ready to enter call
  IN_CALL  // Squad has entered the call
}

model SquadLobby {
  id        String           @id @default(cuid())
  inviterId String           @unique // One lobby per inviter
  memberIds Json             // Array of member user IDs (includes inviter as first element)
  status    SquadLobbyStatus @default(WAITING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  enteredCallAt DateTime?

  @@index([inviterId])
  @@index([status])
  @@map("squad_lobbies")
}

// Broadcast view history (replaces RaincheckSession hack for broadcasts)
model BroadcastViewHistory {
  id        String   @id @default(cuid())
  userId    String   // User who viewed
  roomId    String   // Broadcast room ID
  viewedAt  DateTime @default(now())
  duration  Int?     // Viewing duration in seconds (optional)
  deviceId  String?  // For cross-device sync (optional)
  
  @@index([userId])
  @@index([roomId])
  @@index([userId, roomId])
  @@index([viewedAt])
  @@map("broadcast_view_history")
}

// Broadcast engagement - Comments
model BroadcastComment {
  id        String   @id @default(cuid())
  roomId    String   // Broadcast room ID
  userId    String   // User who commented
  comment   String   // Comment text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // Soft delete
  
  @@index([roomId])
  @@index([userId])
  @@index([createdAt])
  @@map("broadcast_comments")
}

// Broadcast engagement - Shares
model BroadcastShare {
  id        String   @id @default(cuid())
  roomId    String   // Broadcast room ID
  userId    String   // User who shared
  shareType String   @default("link") // link, social, etc.
  createdAt DateTime @default(now())
  
  @@index([roomId])
  @@index([userId])
  @@index([createdAt])
  @@map("broadcast_shares")
}

// Broadcast follows - Viewer follows broadcast participant
model BroadcastFollow {
  id              String   @id @default(cuid())
  followerId      String   // User who is following (viewer)
  followedUserId  String   // User being followed (broadcast participant)
  roomId          String   // Broadcast room ID where the follow happened
  createdAt       DateTime @default(now())
  
  @@unique([followerId, followedUserId, roomId]) // Prevent duplicate follows for same broadcast
  @@index([followerId])
  @@index([followedUserId])
  @@index([roomId])
  @@index([createdAt])
  @@map("broadcast_follows")
}
