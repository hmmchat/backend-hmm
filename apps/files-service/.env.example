PORT=3000
NODE_ENV=development

# Database (if used)
DATABASE_URL=postgresql://user:password@localhost:5432/appdb?schema=public

# Auth (JWT/JWKS)
JWT_ISSUER=backend-hmm
JWT_AUDIENCE=backend-hmm
# AUTH_PRIVATE_KEY_PEM=...
# AUTH_PUBLIC_JWKS_URL=http://localhost:3010/.well-known/jwks.json

# Redis (if used)
REDIS_URL=redis://localhost:6379

# --- Files: image limits ---
# Max image dimensions (resize if larger)
IMAGE_MAX_WIDTH=2000
IMAGE_MAX_HEIGHT=2000
# Max image file size (MB)
IMAGE_MAX_FILE_SIZE_MB=10
# Default thumbnail side (px)
IMAGE_THUMBNAIL_SIZE=200
# Multipart upload max size (MB); should be >= IMAGE_MAX_FILE_SIZE_MB
FILE_UPLOAD_MAX_SIZE_MB=10
# Default limit for GET /me/files
FILES_LIST_DEFAULT_LIMIT=50

# R2/S3 (files-service)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
