{
  "name": "@apps/files-service",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "start:dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate && node scripts/postinstall-prisma.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "echo '⚠️  WARNING: prisma:push can drop tables! Use prisma:migrate instead.' && prisma db push --accept-data-loss",
    "prisma:deploy": "prisma migrate deploy",
    "postinstall": "node scripts/postinstall-prisma.js"
  },
  "dependencies": {
    "@hmm/common": "*",
    "@nestjs/common": "^10.4.20",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^10.4.20",
    "@nestjs/platform-fastify": "^10.4.20",
    "@prisma/client": "^6.0.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "fastify-multipart": "^5.4.0",
    "sharp": "^0.33.5",
    "zod": "^3.23.8",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.2",
    "@nestjs/testing": "^10.4.7",
    "@types/node": "^25.0.3",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.0.0",
    "typescript": "^5.6.3"
  }
}
