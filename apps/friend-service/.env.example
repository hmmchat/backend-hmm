# Friend Service - Environment Example
# Copy to .env and fill in values

PORT=3009
NODE_ENV=development

# Database. Use real Postgres credentials. Can be same DB as wallet/payment if shared.
DATABASE_URL=postgresql://user:password@localhost:5432/friend-service?schema=public

# Redis (caching, rate limits, notification counts)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true

# JWT (verify gateway/auth tokens)
JWT_PUBLIC_JWK={"kty":"OKP","crv":"Ed25519","x":"..."}

# Internal service-to-service auth (API Gateway / other services)
INTERNAL_SERVICE_TOKEN=your-internal-service-token

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Business / product config ---

# Friend request expiry (days)
REQUEST_EXPIRY_DAYS=30

# First message to non-friend (coins)
FIRST_MESSAGE_COST_COINS=10

# Hotline message cost (coins) - messaging from call history
HOTLINE_MESSAGE_COST=10

# Message and spam limits (tune without code changes)
MAX_MESSAGE_LENGTH=1000
SPAM_DETECTION_WINDOW_SECONDS=60

# Notification count cache (seconds) - how long counts are cached per user
NOTIFICATION_COUNT_CACHE_TTL_SECONDS=30

# Friends wall - photos per page
FRIENDS_WALL_PHOTOS_PER_PAGE=35

# Friends wall share image - cache TTL (seconds), product link, Puppeteer (optional)
FRIENDS_WALL_CACHE_TTL=86400
PRODUCT_LINK=https://hmmchat.live
# PUPPETEER_EXECUTABLE_PATH=/path/to/chromium

# Friends wall share image retention (days) - cleanup job
FRIENDS_WALL_IMAGE_RETENTION_DAYS=30

# Rate limits (requests per window)
NOTIFICATION_RATE_LIMIT=60
NOTIFICATION_RATE_LIMIT_WINDOW=60
CONVERSATION_RATE_LIMIT=30
CONVERSATION_RATE_LIMIT_WINDOW=60
SHARE_RATE_LIMIT=10
SHARE_RATE_LIMIT_WINDOW=60
MESSAGE_RATE_LIMIT=10
GIFT_RATE_LIMIT=5
RATE_LIMIT_WINDOW=60

# --- Service URLs (when not using API Gateway or for server-to-server) ---

AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
WALLET_SERVICE_URL=http://localhost:3005
STREAMING_SERVICE_URL=http://localhost:3006
FILES_SERVICE_URL=http://localhost:3008

# Deep link base URL (e.g. for broadcast invites)
APP_DEEP_LINK_BASE_URL=https://app.hmmchat.live

# --- Test mode (optional) ---
# TEST_MODE=true
