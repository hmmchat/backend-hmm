{
  "name": "@apps/friend-service",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "start:dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "prisma:generate": "(prisma generate --schema=prisma/schema.prisma 2>&1 || true) && node scripts/postinstall-prisma.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "echo '⚠️  WARNING: prisma:push can drop tables! Use prisma:migrate instead.' && prisma db push --accept-data-loss",
    "prisma:deploy": "prisma migrate deploy",
    "seed:gifts": "tsx prisma/seed-gifts.ts",
    "migrate:conversations": "tsx prisma/migrate-conversations.ts",
    "postinstall": "node scripts/postinstall-prisma.js",
    "lint": "echo \"no lint configured yet\"",
    "test": "echo \"no tests yet\""
  },
  "dependencies": {
    "@hmm/common": "*",
    "@nestjs/common": "^10.4.20",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^10.4.20",
    "@nestjs/platform-fastify": "^10.4.20",
    "@nestjs/schedule": "^4.1.1",
    "@prisma/client": "^6.0.0",
    "@prisma/engines": "^6.0.0",
    "form-data": "^4.0.1",
    "ioredis": "^5.4.1",
    "node-fetch": "^3.3.2",
    "puppeteer": "^23.11.1",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.2",
    "@nestjs/testing": "^10.4.7",
    "@types/form-data": "^2.5.0",
    "@types/node": "^25.0.3",
    "prisma": "6.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
