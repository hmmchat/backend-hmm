// Prisma schema for moderation-service
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

// User-submitted dares for moderation team review
model DareSubmission {
  id          String   @id @default(cuid())
  userId      String   // User who submitted the dare
  dareText    String   // The custom dare text
  status      DareSubmissionStatus @default(PENDING)
  reviewedBy  String?  // Admin/moderation team member who reviewed
  reviewedAt  DateTime?
  notes       String?  // Internal notes from moderation team
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("dare_submissions")
}

enum DareSubmissionStatus {
  PENDING     // Awaiting moderation review
  APPROVED    // Approved by moderation team
  REJECTED    // Rejected by moderation team
}

enum KycDecision {
  VERIFIED
  REJECTED
  REVIEW
  REVOKED
}

model KycSession {
  id             String      @id @default(cuid())
  userId         String
  moderatorId    String
  startedAt      DateTime    @default(now())
  endedAt        DateTime?
  decision       KycDecision?
  decisionReason String?
  reportCount    Int         @default(0)
  kycRiskScore   Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  feedbacks      KycFeedback[]

  @@index([userId, createdAt])
  @@index([moderatorId, createdAt])
  @@index([decision])
  @@map("kyc_sessions")
}

model KycFeedback {
  id             String   @id @default(cuid())
  userId         String
  sessionId      String?
  session        KycSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  questionOne    String
  questionTwo    String
  rewardedCoins  Int      @default(0)
  rewardIssued   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, sessionId])
  @@index([userId, createdAt])
  @@map("kyc_feedback")
}
