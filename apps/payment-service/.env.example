PORT=3007
NODE_ENV=development

# Database (required for payment/redemption). Use real Postgres credentials.
# Can be the same DB as wallet-service or friend-service if shared.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payment-service?schema=public

# Auth (JWT/JWKS)
JWT_ISSUER=backend-hmm
JWT_AUDIENCE=backend-hmm
# AUTH_PRIVATE_KEY_PEM=...
# AUTH_PUBLIC_JWKS_URL=http://localhost:3010/.well-known/jwks.json

# Redis (if used)
REDIS_URL=redis://localhost:6379

# Request timeout (ms). Should be less than gateway timeout
PAYMENT_REQUEST_TIMEOUT_MS=8000
# Prisma $transaction timeout (ms)
PAYMENT_TRANSACTION_TIMEOUT_MS=30000
# Default limit for purchase/redemption history (1–100)
PAYMENT_HISTORY_DEFAULT_LIMIT=50
# Wallet client: get balance timeout (ms)
WALLET_CLIENT_GET_BALANCE_TIMEOUT_MS=5000
# Wallet client: add/deduct coins timeout (ms)
WALLET_CLIENT_REQUEST_TIMEOUT_MS=10000

# Coins per 1 diamond (e.g. 50 = 50 coins per diamond). Used for upsell "coins needed" and conversion. Align with wallet-service.
DIAMOND_TO_COIN_RATE=50

# R2/S3 (files-service)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
