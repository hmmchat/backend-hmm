PORT=3006
NODE_ENV=development

# Database (if used)
DATABASE_URL=postgresql://user:password@localhost:5432/appdb?schema=public

# Auth (JWT/JWKS)
JWT_ISSUER=backend-hmm
JWT_AUDIENCE=backend-hmm
# AUTH_PRIVATE_KEY_PEM=...
# AUTH_PUBLIC_JWKS_URL=http://localhost:3010/.well-known/jwks.json

# Redis (if used)
REDIS_URL=redis://localhost:6379

# --- Streaming: Mediasoup ---
MEDIASOUP_WORKERS=4
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
# Worker restart: max attempts, backoff base (ms), backoff max (ms)
MEDIASOUP_MAX_RESTART_ATTEMPTS=5
# Base delay (ms) for exponential backoff between restarts
MEDIASOUP_RESTART_BACKOFF_BASE_MS=2000
# Max backoff (ms) cap
MEDIASOUP_RESTART_BACKOFF_MAX_MS=32000

# --- Streaming: In-call chat ---
# Max characters per chat message
CHAT_MAX_MESSAGE_LENGTH=1000
# Max messages kept in memory per room
CHAT_HISTORY_MEMORY_LIMIT=100
# Default limit for get message history
CHAT_HISTORY_DEFAULT_LIMIT=50

# R2/S3 (files-service)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
