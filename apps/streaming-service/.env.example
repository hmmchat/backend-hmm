PORT=3006
NODE_ENV=development

# Fastify HTTP request timeout (ms). Must exceed worst-case user-service status fetch used by room reconcile (see USER_SERVICE_TIMEOUT_MS).
# FASTIFY_REQUEST_TIMEOUT_MS=25000

# Database (if used)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/streaming-service?schema=public

# Auth (JWT/JWKS)
JWT_ISSUER=backend-hmm
JWT_AUDIENCE=backend-hmm
# AUTH_PRIVATE_KEY_PEM=...
# AUTH_PUBLIC_JWKS_URL=http://localhost:3010/.well-known/jwks.json

# Redis (if used)
REDIS_URL=redis://localhost:6379
# Production (split droplets): often redis://<backend-public-ip>:6380 behind nginx stream; see docs/deployment/BEAM_PRODUCTION.md

# --- Streaming: multi-node SFU registry ---
# Set a stable unique ID per SFU pod/VM. Defaults to hostname-pid for local dev.
# STREAMING_NODE_ID=streaming-sfu-1
# Public/internal HTTP URL for this exact SFU node. Returned in room affinity metadata.
# STREAMING_NODE_HTTP_URL=https://sfu-1.internal.beam.place
# WebSocket URL for this exact SFU node. Clients/gateway can use this when receiving room-reroute.
# STREAMING_NODE_WS_URL=wss://sfu-1.internal.beam.place/streaming/ws
# Optional region/zone label for capacity planning.
# STREAMING_NODE_REGION=ap-south-1a
# Disable Redis-backed node registry only for local/dev fallback.
# STREAMING_NODE_REGISTRY_ENABLED=true
# STREAMING_NODE_HEARTBEAT_INTERVAL_MS=5000
# STREAMING_NODE_HEARTBEAT_TTL_SECONDS=20
# STREAMING_ROOM_AFFINITY_TTL_SECONDS=86400

# S2S URLs when nginx on api.beam.place proxies /users/test, /discovery/internal, /internal/friends, /test/* (see docs)
# USER_SERVICE_URL=https://api.beam.place
# DISCOVERY_SERVICE_URL=https://api.beam.place
# FRIEND_SERVICE_URL=https://api.beam.place
# WALLET_SERVICE_URL=https://api.beam.place

# Optional: set to "true" to skip reconciling stale call_participants / viewers with user-service status (not recommended in production)
# STREAMING_SKIP_STATUS_RECONCILE=

# Min milliseconds between user-service reconcile runs per user on GET /streaming/users/:userId/room (default 30000). Reduces poll storms; 0 = always reconcile.
# ROOM_RECONCILE_MIN_INTERVAL_MS=30000
# Short in-process cache windows for hot polling/signaling paths.
# ROOM_DETAILS_CACHE_TTL_MS=1000
# ACTIVE_ROOM_LOOKUP_CACHE_TTL_MS=1000
# ACTIVE_BROADCASTS_CACHE_TTL_MS=1500
# ROOM_MEMBERSHIP_CACHE_TTL_MS=5000

# Pull stranger window duration (milliseconds)
# Example: 60000 = 1 minute
PULL_STRANGER_WINDOW_MS=60000

# --- Streaming: Mediasoup ---
# Use 1 worker for local dev. Production defaults to CPU-aware workers when unset.
MEDIASOUP_WORKERS=1
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
# Per-node RTP port range. Increase per SFU node for high concurrency.
# MEDIASOUP_RTC_MIN_PORT=40000
# MEDIASOUP_RTC_MAX_PORT=49999
# WebRTC transport initial outgoing bitrate (bps); higher helps 3–4 person SFU (default 2500000)
# MEDIASOUP_INITIAL_OUT_BITRATE=2500000
# Optional cap for incoming media sent to the SFU (bps). Leave unset to avoid server-side quality caps.
# MEDIASOUP_MAX_INCOMING_BITRATE=
# Enable high-volume realtime media debug logs only when diagnosing signaling.
# STREAMING_REALTIME_DEBUG=false
# Max concurrent viewers per broadcast on this SFU room; 0 disables the cap.
# MAX_VIEWERS_PER_BROADCAST=1000
# Worker restart: max attempts, backoff base (ms), backoff max (ms)
MEDIASOUP_MAX_RESTART_ATTEMPTS=5
# Base delay (ms) for exponential backoff between restarts
MEDIASOUP_RESTART_BACKOFF_BASE_MS=2000
# Max backoff (ms) cap
MEDIASOUP_RESTART_BACKOFF_MAX_MS=32000

# --- Streaming: In-call chat ---
# Max characters per chat message
CHAT_MAX_MESSAGE_LENGTH=1000
# Max messages kept in memory per room
CHAT_HISTORY_MEMORY_LIMIT=100
# Default limit for get message history
CHAT_HISTORY_DEFAULT_LIMIT=50

# --- GIFs (GIPHY) ---
GIPHY_API_KEY=
# Optional override for self-hosting / proxying the API
# GIPHY_BASE_URL=https://api.giphy.com/v1
# Cache TTL for search results (seconds)
GIF_SEARCH_CACHE_TTL_SECONDS=3600

# R2/S3 (files-service)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
