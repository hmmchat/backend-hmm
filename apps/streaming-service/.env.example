PORT=3006
NODE_ENV=development

# Database (if used)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/streaming-service?schema=public

# Auth (JWT/JWKS)
JWT_ISSUER=backend-hmm
JWT_AUDIENCE=backend-hmm
# AUTH_PRIVATE_KEY_PEM=...
# AUTH_PUBLIC_JWKS_URL=http://localhost:3010/.well-known/jwks.json

# Redis (if used)
REDIS_URL=redis://localhost:6379
# Production (split droplets): often redis://<backend-public-ip>:6380 behind nginx stream; see docs/deployment/BEAM_PRODUCTION.md

# S2S URLs when nginx on api.beam.place proxies /users/test, /discovery/internal, /internal/friends, /test/* (see docs)
# USER_SERVICE_URL=https://api.beam.place
# DISCOVERY_SERVICE_URL=https://api.beam.place
# FRIEND_SERVICE_URL=https://api.beam.place
# WALLET_SERVICE_URL=https://api.beam.place

# Optional: set to "true" to skip reconciling stale call_participants / viewers with user-service status (not recommended in production)
# STREAMING_SKIP_STATUS_RECONCILE=

# --- Streaming: Mediasoup ---
# Use 1 worker for local dev (faster startup, lower resource usage)
MEDIASOUP_WORKERS=1
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
# Worker restart: max attempts, backoff base (ms), backoff max (ms)
MEDIASOUP_MAX_RESTART_ATTEMPTS=5
# Base delay (ms) for exponential backoff between restarts
MEDIASOUP_RESTART_BACKOFF_BASE_MS=2000
# Max backoff (ms) cap
MEDIASOUP_RESTART_BACKOFF_MAX_MS=32000

# --- Streaming: In-call chat ---
# Max characters per chat message
CHAT_MAX_MESSAGE_LENGTH=1000
# Max messages kept in memory per room
CHAT_HISTORY_MEMORY_LIMIT=100
# Default limit for get message history
CHAT_HISTORY_DEFAULT_LIMIT=50

# R2/S3 (files-service)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
