{
  "name": "@apps/streaming-service",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "start:dev": "nest start --watch",
    "build": "nest build",
    "start": "NODE_ENV=test node dist/main.js",
    "prisma:generate": "(prisma generate --schema=prisma/schema.prisma 2>&1 || true) && node scripts/postinstall-prisma.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "echo '⚠️  WARNING: prisma:push can drop tables! Use prisma:migrate instead.' && prisma db push --accept-data-loss",
    "prisma:deploy": "prisma migrate deploy",
    "postinstall": "node scripts/postinstall-prisma.js",
    "lint": "echo \"no lint configured yet\"",
    "test": "echo \"no tests yet\""
  },
  "dependencies": {
    "@fastify/websocket": "^7.1.1",
    "@hmm/common": "*",
    "@nestjs/common": "^10.4.20",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^10.4.20",
    "@nestjs/platform-fastify": "^10.4.20",
    "@nestjs/platform-socket.io": "^10.4.7",
    "@nestjs/websockets": "^10.4.7",
    "@prisma/client": "6.0.0",
    "@prisma/engines": "^7.2.0",
    "mediasoup": "^3.14.11",
    "node-fetch": "^3.3.2",
    "uuid": "^11.0.3",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.2",
    "@nestjs/testing": "^10.4.7",
    "@types/node": "^25.0.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "prisma": "6.0.0",
    "typescript": "^5.6.3"
  }
}
