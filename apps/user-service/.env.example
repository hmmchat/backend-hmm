PORT=3002
NODE_ENV=development

# Database (if used)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/user-service?schema=public

# Auth (JWT/JWKS)
JWT_ISSUER=backend-hmm
JWT_AUDIENCE=backend-hmm
# AUTH_PRIVATE_KEY_PEM=...
# AUTH_PUBLIC_JWKS_URL=http://localhost:3010/.well-known/jwks.json

# Redis (if used)
REDIS_URL=redis://localhost:6379

# Shared service-to-service token used for internal referral endpoints
INTERNAL_SERVICE_TOKEN=change-me-in-production

# Referral rewards
# Reward (coins) for user who invited a friend
REFERRAL_REWARD_REFERRER=100
# Reward (coins) for newly referred user
REFERRAL_REWARD_REFERRED=50

# --- User: nearby & list defaults ---
# GET /users/nearby: default radius (km) and limit
NEARBY_DEFAULT_RADIUS_KM=10
NEARBY_DEFAULT_LIMIT=50
# GET /metrics/cities: default limit
CITIES_MAX_USERS_DEFAULT_LIMIT=20
# POST /users/discovery: default limit
DISCOVERY_USERS_DEFAULT_LIMIT=100
# GET /brands/search and GET /music/search: default limit
SEARCH_DEFAULT_LIMIT=20

# --- Report weights (POST /users/report) ---
# reportCount stores the sum of weights (report score); discovery compares it to REPORT_THRESHOLD (in discovery-service).
# REPORT_WEIGHT_DEFAULT=1
# REPORT_WEIGHT_FACE_CARD=5
# REPORT_WEIGHT_OFFLINE_CARD=5
# REPORT_WEIGHT_HOST=10
# REPORT_WEIGHT_PARTICIPANT_HOST=3
# REPORT_WEIGHT_PARTICIPANT=5
# Dashboard admin report (POST /admin/users/:id/report) adds max of the role weights above, unless overridden:
# REPORT_WEIGHT_ADMIN_DASHBOARD=15

# --- KYC ---
# Master switch for KYC fields/automation.
# KYC_ENABLED=false
# Auto revoke verified status when risk score exceeds threshold.
# KYC_AUTO_REVOKE_ENABLED=false
# Auto expire verified status based on kycExpiresAt.
# KYC_AUTO_EXPIRE_ENABLED=false
# KYC_AUTO_EXPIRE_INTERVAL_MS=300000
# KYC_RISK_THRESHOLD=50
# KYC_REPORT_NORM_FACTOR=100
# KYC_EXPIRY_DAYS=90

# Brand logos (optional). Base URL for self-hosted brand logos.
# Example: https://cdn.example.com/brand-logos
# Seed will set logoUrl = {base}/{slug}.png (e.g. apple.png, nike.png)
# BRAND_LOGO_BASE_URL=

# R2/S3 (files-service)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Spotify (optional, enables GET /music/search)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Brandfetch (optional, enables external brand search for GET /brands/search)
BRANDFETCH_CLIENT_ID=
# Set to false to disable Brandfetch and use DB-only fallback search
BRANDFETCH_ENABLED=true
# Comma-separated seed queries for GET /brands (suggestions). Defaults to a built-in list if unset.
# BRANDFETCH_DEFAULT_QUERIES=tech,retail,fashion,food,sport
