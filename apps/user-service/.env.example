PORT=3000
NODE_ENV=development

# Database (if used)
DATABASE_URL=postgresql://user:password@localhost:5432/appdb?schema=public

# Auth (JWT/JWKS)
JWT_ISSUER=backend-hmm
JWT_AUDIENCE=backend-hmm
# AUTH_PRIVATE_KEY_PEM=...
# AUTH_PUBLIC_JWKS_URL=http://localhost:3010/.well-known/jwks.json

# Redis (if used)
REDIS_URL=redis://localhost:6379

# --- User: nearby & list defaults ---
# GET /users/nearby: default radius (km) and limit
NEARBY_DEFAULT_RADIUS_KM=10
NEARBY_DEFAULT_LIMIT=50
# GET /metrics/cities: default limit
CITIES_MAX_USERS_DEFAULT_LIMIT=20
# POST /users/discovery: default limit
DISCOVERY_USERS_DEFAULT_LIMIT=100
# GET /brands/search and GET /music/search: default limit
SEARCH_DEFAULT_LIMIT=20

# R2/S3 (files-service)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
