// Prisma schema for user-service
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

// Shared tables with discovery-service
// These tables are managed by discovery-service but need to be in user-service schema
// to prevent them from being dropped when user-service syncs the database
model GenderFilterPreference {
  id               String    @id @default(cuid())
  userId           String    @unique
  genders          Json // Array of Gender enum values: ["MALE", "FEMALE", "NON_BINARY"] (stored as JSON)
  screensRemaining Int       @default(0) // Number of screens remaining for this filter
  expiresAt        DateTime? // When the filter expires (if applicable)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@map("gender_filter_preferences")
}

model RaincheckSession {
  id                String   @id @default(cuid())
  userId            String   // User who rainchecked
  sessionId         String   // Frontend-generated session ID
  raincheckedUserId String   // User who was rainchecked
  city              String?  // City context (null for "anywhere")
  createdAt         DateTime  @default(now())

  @@index([userId, sessionId])
  @@index([userId, city, sessionId])
  @@map("raincheck_sessions")
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum UserStatus {
  AVAILABLE
  ONLINE
  OFFLINE
  MATCHED
  IN_SQUAD
  IN_SQUAD_AVAILABLE
  IN_BROADCAST
  IN_BROADCAST_AVAILABLE
}

model User {
  id            String   @id // Links to auth-service User.id (must match auth-service user id)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Profile Creation Fields (from Figma 1)
  username      String?  // * mandatory, can be duplicate (e.g., common first names like "John", "Sarah")
  dateOfBirth   DateTime? // * mandatory, immutable once set
  gender        Gender?  // Can change once from PREFER_NOT_TO_SAY to any other, but not otherwise
  genderChanged Boolean  @default(false) // Track if user changed from PREFER_NOT_TO_SAY
  displayPictureUrl String? // * mandatory, must be validated for NSFW before acceptance
  
  // Additional Photos (max 4)
  photos        UserPhoto[] @relation("UserPhotos")
  
  // Music Preference (like Instagram Reels - Song + Artist)
  musicPreference Song?  @relation("UserMusicPreference", fields: [musicPreferenceId], references: [id])
  musicPreferenceId String?
  
  // Brand References (4-5 brands from provided list)
  brandPreferences UserBrand[]
  
  // Interests (max 4 from provided list)
  interests     UserInterest[]
  
  // Values (max 4 from provided list)
  values        UserValue[]
  
  // User Status
  status        UserStatus @default(ONLINE)
  
  // Moderation & Flags
  reportCount   Int      @default(0) // Number of reports on this user
  badgeMember   Boolean  @default(false) // 1 = yes, 0 = no
  
  // Intent/Bio (max 50 characters)
  intent        String?  @db.VarChar(50)
  
  // Location (for "miles away" calculation)
  latitude      Float?
  longitude     Float?
  locationUpdatedAt DateTime?
  
  // Preferred City (single city name for location-based matching)
  // null means user can connect with anyone from anywhere
  preferredCity String?
  
  // Video Preferences (on/off)
  videoEnabled  Boolean  @default(true)
  
  // Profile Completion Tracking
  profileCompleted Boolean @default(false) // True when username, DOB, gender, displayPicture are set

  // Badge system
  activeBadgeId String?  // Currently selected badge ID
  badges        UserBadge[]

  @@index([username])
  @@index([status])
  @@index([latitude, longitude]) // For location-based queries
  @@map("users")
}

// Additional Photos (max 4 per user)
model UserPhoto {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserPhotos", fields: [userId], references: [id], onDelete: Cascade)
  url       String   // URL to file in files-service/Cloudflare R2
  order     Int      // Display order (0-3)
  createdAt DateTime @default(now())
  
  @@unique([userId, order])
  @@index([userId])
  @@map("user_photos")
}

// Music Preference (Song + Artist)
model Song {
  id          String   @id @default(cuid())
  name        String   // Song name
  artist      String   // Artist name
  albumArtUrl String?  // Album art URL (from Spotify)
  spotifyId   String?  @unique // Optional: Spotify track ID for reference
  createdAt   DateTime @default(now())
  
  // Users who have this as their music preference
  users       User[]   @relation("UserMusicPreference")
  
  @@unique([name, artist])
  @@index([name, artist])
  @@map("songs")
}

// Brand Preferences (4-5 brands from provided list)
model Brand {
  id          String   @id @default(cuid())
  name        String   @unique // Brand name (e.g., "JBL", "Apple", "Nike", "BMW")
  domain      String?  // Optional: Domain name for Brandfetch API (e.g., "apple.com", "nike.com")
  logoUrl     String?  // Optional: Brand logo URL (fetched from Brandfetch API)
  brandfetchId String? // Optional: Brandfetch brand ID for reference
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  userPreferences UserBrand[]
  
  @@map("brands")
}

model UserBrand {
  id        String   @id @default(cuid())
  userId    String
  brandId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  order     Int      // Display order (0-4)
  createdAt DateTime @default(now())
  
  @@unique([userId, brandId])
  @@unique([userId, order]) // Enforce max 5 brands per user
  @@index([userId])
  @@map("user_brands")
}

// Interests (max 4 from provided list)
// name = sub-genre (what users see/choose), genre = umbrella category
model Interest {
  id        String   @id @default(cuid())
  name      String   @unique // Sub-genre name (e.g., "cricket", "hockey", "sitcoms", "romcoms")
  genre     String?  // Genre/umbrella category (e.g., "sports", "sports", "web series", "web series") - nullable for backward compatibility
  createdAt DateTime @default(now())
  
  userPreferences UserInterest[]
  
  @@index([genre])
  @@map("interests")
}

model UserInterest {
  id        String   @id @default(cuid())
  userId    String
  interestId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interest  Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)
  order     Int      // Display order (0-3)
  createdAt DateTime @default(now())
  
  @@unique([userId, interestId])
  @@unique([userId, order]) // Enforce max 4 interests per user
  @@index([userId])
  @@map("user_interests")
}

// Values (max 4 from provided list)
model Value {
  id        String   @id @default(cuid())
  name      String   @unique // Value name
  createdAt DateTime @default(now())
  
  userPreferences UserValue[]
  
  @@map("values")
}

model UserValue {
  id        String   @id @default(cuid())
  userId    String
  valueId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     Value    @relation(fields: [valueId], references: [id], onDelete: Cascade)
  order     Int      // Display order (0-3)
  createdAt DateTime @default(now())
  
  @@unique([userId, valueId])
  @@unique([userId, order]) // Enforce max 4 values per user
  @@index([userId])
  @@map("user_values")
}

// Shared tables with other services using hmm_user database
// These tables are managed by their respective services but need to be in user-service schema
// to prevent them from being dropped when user-service syncs the database

// From wallet-service - wallet and transactions
model Wallet {
  id        String   @id // Links to auth-service User.id (must match auth-service user id)
  balance   Int      @default(0) // Coin balance (non-negative)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Transaction history
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id        String   @id @default(cuid())
  walletId  String
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount    Int      // Positive for credits, negative for debits
  type      TransactionType
  description String?
  createdAt DateTime @default(now())

  @@index([walletId])
  @@index([createdAt])
  @@map("transactions")
}

enum TransactionType {
  CREDIT      // Coins added (e.g., purchase, reward, bonus)
  DEBIT       // Coins spent (e.g., premium features, gifts)
  REFUND      // Refund for a previous transaction
  ADJUSTMENT  // Manual adjustment by admin
}

// User badges - gifts received that can be displayed as profile badges
model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  giftId    String   // Gift sticker ID (monkey, pikachu, etc.)
  giftName  String   // Gift name for display
  giftEmoji String?  // Gift emoji for display
  receivedAt DateTime @default(now()) // When the gift was received
  createdAt DateTime @default(now())
  
  @@unique([userId, giftId]) // User can only have one of each gift type
  @@index([userId])
  @@map("user_badges")
}
