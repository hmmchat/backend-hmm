PORT=3000
NODE_ENV=development

# Database. Must point to the DB that has wallets and transactions (wallet-service tables).
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/YOUR_DB?schema=public

# Auth (JWT/JWKS)
JWT_ISSUER=backend-hmm
JWT_AUDIENCE=backend-hmm
# AUTH_PRIVATE_KEY_PEM=...
# AUTH_PUBLIC_JWKS_URL=http://localhost:3010/.well-known/jwks.json

# Redis (if used)
REDIS_URL=redis://localhost:6379

# Request timeout (ms). Should be less than gateway timeout
WALLET_REQUEST_TIMEOUT_MS=8000

# Coins per 1 diamond (e.g. 100 = 100 coins to buy 1 diamond). Align with payment-service DIAMOND_TO_COIN_RATE.
DIAMOND_TO_COIN_RATE=100

# R2/S3 (files-service)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
