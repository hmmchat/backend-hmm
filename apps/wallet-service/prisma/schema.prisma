// Prisma schema for wallet-service
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

// Tables owned and managed by wallet-service
// These tables are in the wallet-service database

// Note: User, GenderFilterPreference, RaincheckSession, and other tables are owned by their respective services.
// Access user data via HTTP API calls to user-service.
// Access discovery data via HTTP API calls to discovery-service.

model Wallet {
  id        String   @id // Links to auth-service User.id (must match auth-service user id)
  balance   Int      @default(0) // Coin balance (non-negative)
  diamonds Int      @default(0) // Diamond balance (non-negative); separate from coins
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Transaction history
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id               String            @id @default(cuid())
  walletId         String
  wallet           Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount           Int               // Positive for credits, negative for debits (coins)
  type             TransactionType
  description      String?
  giftId           String?           // Gift sticker ID (monkey, pikachu, etc.) - only for CREDIT transactions from gifts
  diamondAmount    Int?              // Delta for diamonds (positive credit, negative debit); used when transactionKind is DIAMONDS or CONVERSION
  transactionKind  TransactionKind? // COINS = coin-only, DIAMONDS = diamond-only, CONVERSION = coins->diamonds purchase
  createdAt        DateTime         @default(now())

  @@index([walletId])
  @@index([createdAt])
  @@index([giftId]) // Index for querying gifts received
  @@map("transactions")
}

enum TransactionType {
  CREDIT      // Coins added (e.g., purchase, reward, bonus)
  DEBIT       // Coins spent (e.g., premium features, gifts)
  REFUND      // Refund for a previous transaction
  ADJUSTMENT  // Manual adjustment by admin
}

enum TransactionKind {
  COINS       // Coin-only transaction
  DIAMONDS    // Diamond-only transaction
  CONVERSION  // Coins to diamonds purchase (coin debit + diamond credit)
}
