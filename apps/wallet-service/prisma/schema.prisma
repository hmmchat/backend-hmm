// Prisma schema for wallet-service
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

// Shared tables with other services using hmm_user database
// These tables are managed by their respective services but need to be in wallet-service schema
// to prevent them from being dropped when wallet-service syncs the database

// From user-service - user profile and preferences
enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum UserStatus {
  AVAILABLE
  OFFLINE
  IN_SQUAD
  IN_SQUAD_AVAILABLE
  IN_BROADCAST
  IN_BROADCAST_AVAILABLE
  VIEWER
}

// From discovery-service - gender filter preferences
model GenderFilterPreference {
  id               String    @id @default(cuid())
  userId           String    @unique
  genders          Json // Array of Gender enum values: ["MALE", "FEMALE", "NON_BINARY"] (stored as JSON)
  screensRemaining Int       @default(0) // Number of screens remaining for this filter
  expiresAt        DateTime? // When the filter expires (if applicable)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@map("gender_filter_preferences")
}

// From discovery-service - raincheck sessions
model RaincheckSession {
  id                String   @id @default(cuid())
  userId            String   // User who rainchecked
  sessionId         String   // Frontend-generated session ID
  raincheckedUserId String   // User who was rainchecked
  city              String?  // City context (null for "anywhere")
  createdAt         DateTime  @default(now())

  @@index([userId, sessionId])
  @@index([userId, city, sessionId])
  @@map("raincheck_sessions")
}

model Wallet {
  id        String   @id // Links to auth-service User.id (must match auth-service user id)
  balance   Int      @default(0) // Coin balance (non-negative)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Transaction history
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id        String   @id @default(cuid())
  walletId  String
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount    Int      // Positive for credits, negative for debits
  type      TransactionType
  description String?
  giftId    String?  // Gift sticker ID (monkey, pikachu, etc.) - only for CREDIT transactions from gifts
  createdAt DateTime @default(now())

  @@index([walletId])
  @@index([createdAt])
  @@index([giftId]) // Index for querying gifts received
  @@map("transactions")
}

enum TransactionType {
  CREDIT      // Coins added (e.g., purchase, reward, bonus)
  DEBIT       // Coins spent (e.g., premium features, gifts)
  REFUND      // Refund for a previous transaction
  ADJUSTMENT  // Manual adjustment by admin
}
